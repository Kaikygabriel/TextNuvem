@page "/Customer/Login"
@using System.Text
@using System.Text.Json
@using TextNuvem.Dtos.Customers
@using TextNuvem.Service
@inject IHttpClientFactory Factory
@inject NavigationManager Nav
@inject LocalStorageService serviceStorage


<div class="login-page">
    <div class="login-card">

        <div class="login-header">
            <h3>Welcome Back</h3>
            <p>Entre na sua conta</p>
        </div>

        <EditForm Model="_customer" OnValidSubmit="Handle" FormName="handle">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-4">
                <label for="email" class="form-label">Email</label>

                <InputText
                    id="email"
                    type="email"
                    class="form-control custom-input"
                    @bind-Value="_customer.Email" />
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Password</label>

                <InputText
                    id="password"
                    type="password"
                    class="form-control custom-input"
                    @bind-Value="_customer.Password" />
            </div>

            <button type="submit" class="btn login-btn w-100">
                Login
            </button>

        </EditForm>

        <div class="register-link">
            Não tem conta?
            <a href="/Customer/Register">Registrar</a>
        </div>

    </div>
</div>

@code 
{
    private CustomerLoginDto _customer { get; set; } = new();
    
    public async Task Handle()
    {
        var client = Factory.CreateClient("Api");

        var jsonRequest = JsonSerializer.Serialize(_customer);
        var content = new StringContent(
            jsonRequest,
            Encoding.UTF8,
            "application/json");
        
        var response = await client.PostAsync("/Customer/Login",content);

        if (!response.IsSuccessStatusCode)
        {
            var error = await response.Content.ReadAsStringAsync();
            Nav.NavigateTo("/");
            return;
        }
        
        var raw = await response.Content.ReadAsStringAsync();
        var responseBody = await response.Content.ReadAsStreamAsync();
        
        var options = new JsonSerializerOptions 
        { 
            PropertyNameCaseInsensitive = true 
        };
        var json = JsonSerializer.Deserialize<AuthCustomerResponse>(responseBody,options);

        await serviceStorage.AddAuthCustomerInStorage(json);
        
        Nav.NavigateTo("/");
    }
}