@page "/Editor/{id:guid}"
@using RestSharp
@using TextNuvem.Dtos.Folder
@using TextNuvem.Dtos
@using TextNuvem.Dtos.Projects
@using TextNuvem.Service
@layout EmptyLayout
@inject IJSRuntime JS
@inject CompactorService service;
@inject NavigationManager Nav

<div class="editor-container">
    <aside class="sidebar">
        <div class="sidebar-header d-flex align-items-center justify-content-sm-around flex-row">
            
            <a class="btn btn-sm btn-primary" href="/">
                Previous
            </a>
            
            <h6>Files</h6>
            <button class="btn btn-sm btn-primary" @onclick="Save">
                Save
            </button>

        </div>

        <div class="sidebar-content">
            @if (_root is not null)
            {
                @RenderFolder(_root)
            }
        </div>
        
    </aside>

    <main class="editor">
        @if (_selectedFile is null)
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
                <h4>Select a file</h4>
                <p>Choose a file on the left to edit.</p>
            </div>
        }
        else
        {
            <div class="editor-header">
                <div class="file-info">
                    <i class="bi bi-file-earmark-code"></i>
                    <strong>@_selectedFile.Name</strong>
                </div>

                <div style="display:flex; align-items:center; gap:12px;">
                    <small class="file-path">@_selectedFile.Name</small>
                    
                </div>
            </div>

            <div id="monaco-editor" class="monaco-host"></div>
        }
    </main>
</div>

@code {
    [Parameter] 
    public Guid id { get; set; }
    
    private FolderDto? _root;
    private File? _selectedFile;
    private string _selectedContent = "";
    private IJSObjectReference? _module;
    private bool _editorReady;
    private bool _pendingEditorInit;
    private string _errorMessage;
    
    private async Task Save()
    {
        Console.WriteLine("Chamou");
        var client = new RestClient();
        var request = new RestRequest("https://localhost:7249/Project/Update/Files",Method.Put)
            .AddJsonBody(
                new {
                projectId = id,
                compressFolders = service.CompressObject(new List<FolderDto>{_root})
            });
        var response = await client.ExecuteAsync(request);
        
        if (!response.IsSuccessStatusCode)
        {
            Console.WriteLine("Caiu aqui");
            _errorMessage = response.Content;
            return;
        }
        
    }
    
    protected override async Task OnInitializedAsync()
    {
        var client = new RestClient();
        var request = new RestRequest($"https://localhost:7249/Project?ProjectId={id}");
        var response = await client.GetAsync<GetProjectDto>(request);
        if (response is null)
            Nav.NavigateTo("/");

        _root = service.DecompressObject<IEnumerable<FolderDto>>(response?.ContentFolders).FirstOrDefault();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./js/monacoInterop.js"
            );

            return;
        }

        if (_pendingEditorInit && _module is not null && _selectedFile is not null)
        {
            await _module.InvokeVoidAsync(
                "createEditor",
                "monaco-editor",
                _selectedContent,
                GetLanguage(_selectedFile.Name)
            );

            _editorReady = true;
            _pendingEditorInit = false;
        }
    }
    
    private static string GetLanguage(string fileName)
    {
        if (fileName.EndsWith(".cs", StringComparison.OrdinalIgnoreCase))
            return "csharp";

        if (fileName.EndsWith(".js", StringComparison.OrdinalIgnoreCase))
            return "javascript";

        if (fileName.EndsWith(".ts", StringComparison.OrdinalIgnoreCase))
            return "typescript";

        if (fileName.EndsWith(".html", StringComparison.OrdinalIgnoreCase))
            return "html";

        if (fileName.EndsWith(".css", StringComparison.OrdinalIgnoreCase))
            return "css";

        if (fileName.EndsWith(".json", StringComparison.OrdinalIgnoreCase))
            return "json";

        if (fileName.EndsWith(".md", StringComparison.OrdinalIgnoreCase))
            return "markdown";

        return "plaintext";
    }

    RenderFragment RenderFolder(FolderDto folder) => @<div class="folder">
        <div class="folder-name">
            <i class="bi bi-folder2"></i>
            <span>@folder.Path</span>
        </div>

        @foreach (var file in folder.Files)
        {
            <div class="file @( _selectedFile?.Name == file.Name ? "active" : "" )"
                 @onclick="() => SelectFile(file)">
                <i class="bi bi-file-earmark"></i>
                <span>@file.Name</span>
            </div>
        }

        @foreach (var sub in folder.Folders)
        {
            @RenderFolder(sub)
        }
    </div>;

    private async Task SelectFile(File file)
    {
        if (_selectedFile is not null && _editorReady)
        {
            await SaveCurrentFile();
        }

        _selectedFile = file;
        _selectedContent = file.Content;

        if (_editorReady && _module is not null)
        {
            await _module.InvokeVoidAsync("setEditorValue", _selectedContent);
            await _module.InvokeVoidAsync("setLanguage", GetLanguage(file.Name));
        }
        else
        {
            _pendingEditorInit = true;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveCurrentFile()
    {
        if (_selectedFile is null || _module is null || _root is null)
            return;

        var content = await _module.InvokeAsync<string>("getEditorValue");

        var fileInTree = FindFileById(_root, _selectedFile.Name);
        if (fileInTree is null)
            return;

        fileInTree.Content = content;
        _selectedContent = content;
        _selectedFile = fileInTree;
    }
    
    private static File? FindFileById(FolderDto folder, string name)
    {
        var file = folder.Files.FirstOrDefault(f => f.Name == name);
        if (file is not null)
            return file;

        foreach (var subFolder in folder.Folders)
        {
            var found = FindFileById(subFolder, name);
            if (found is not null)
                return found;
        }

        return null;
    }
    
    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
            await _module.DisposeAsync();
    }
}